{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(.env)",
      "Edit(./.env)",
      "Edit(.env)",
      "Write(./.env)",
      "Write(.env)",
      "Read(./.env.local)",
      "Read(.env.local)",
      "Edit(./.env.local)",
      "Edit(.env.local)",
      "Write(./.env.local)",
      "Write(.env.local)",
      "Bash(cat .env)",
      "Bash(cat ./.env)",
      "Bash(cat .env.local)",
      "Bash(cat ./.env.local)",
      "Bash(less .env)",
      "Bash(less ./.env)",
      "Bash(more .env)",
      "Bash(more ./.env)",
      "Bash(head .env)",
      "Bash(head ./.env)",
      "Bash(tail .env)",
      "Bash(tail ./.env)",
      "Bash(source .env)",
      "Bash(source ./.env)",
      "Bash(. .env)",
      "Bash(. ./.env)",
      "Bash(grep:* .env)",
      "Bash(grep:* ./.env)",
      "Bash(sed:* .env)",
      "Bash(awk:* .env)",
      "Bash(cp .env:*)",
      "Bash(cp ./.env:*)",
      "Bash(mv .env:*)",
      "Bash(mv ./.env:*)",
      "Bash(od .env)",
      "Bash(xxd .env)",
      "Bash(hexdump .env)",
      "Bash(printenv)",
      "Bash(printenv:*)",
      "Bash(env)",
      "Bash(export -p)",
      "Read(./.playwright-profile/:*)",
      "Read(./.playwright-mcp/:*)"
    ]
  }
}
